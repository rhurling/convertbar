{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ConvertBar",
  "version": "0.8.1",
  "identifier": "com.convertbar.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ConvertBar",
        "width": 400,
        "height": 500,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBNkFCQkU4QjY5QTAwRDYKUldUV0FKcTI2THRxV2lXL3Evb0pqVVhrK2Y2WHhnaG9MTUVFWTJOaWhJYml6TXNGL2FjcktCYU0K",
      "endpoints": [
        "https://github.com/rhurling/convertbar/releases/latest/download/latest.json"
      ]
    }
  }
}
